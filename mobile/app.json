{
  "expo": {
    "name": "CropSentinel",
    "slug": "faraway",
    "version": "1.0.0",
    "icon": "./src/assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "faraway",
    "plugins": [
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./src/assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7d0a067d-e0c4-415f-a7ce-2d085db61167"
      }
    },
    "android": {
      "package": "com.yeshbind.faraway"
    }
  }
}
